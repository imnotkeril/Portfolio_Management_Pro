# Copy to .env and adjust. Never commit .env with real secrets.
#
# Application
APP_NAME=Portfolio Management Terminal
APP_VERSION=1.0.0
DEBUG=false

# Auth (Phase 2) — set AUTH_DISABLED=true for Streamlit local dev without login
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_DISABLED=false

# Database (SQLAlchemy URL)
# Docker Compose (postgres service): use host "postgres" inside containers, "localhost" on host
DATABASE_URL=postgresql+psycopg2://portfolio:portfolio@localhost:5432/portfolio
# Local SQLite (Streamlit / pytest without Postgres):
# DATABASE_URL=sqlite:///./data/wmc.db
DATABASE_ECHO=false

# Optional API keys (leave empty if unused)
ALPHA_VANTAGE_API_KEY=
IEX_CLOUD_API_KEY=

# Yahoo Finance
YAHOO_FINANCE_ENABLED=true

# Cache
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
PRICE_CACHE_DIR=data/cache/prices

# Performance
MAX_WORKERS=4
CALCULATION_TIMEOUT_SECONDS=30

# Risk-free rate (annual, decimal)
RISK_FREE_RATE=0.0435

# Portfolio constraints
MAX_PORTFOLIO_POSITIONS=100
MIN_POSITION_WEIGHT=0.0
MAX_POSITION_WEIGHT=1.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Stripe billing (Phase 5)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...
FRONTEND_URL=http://localhost:3000
BILLING_ENFORCEMENT=true
